# Porta em que o servidor NestJS vai escutar
PORT=3080

# Credenciais da API do Trello
# Obtenha em: https://trello.com/app-key
TRELLO_KEY=sua_key_aqui
TRELLO_TOKEN=seu_token_aqui

# OAuth Secret da aplicação Trello (diferente do token).
# Obtenha em: https://trello.com/app-key → campo "Secret"
# Necessário apenas quando TRELLO_SKIP_SIGNATURE=false
TRELLO_OAUTH_SECRET=

# ID do board do Trello onde os cards serão monitorados
TRELLO_BOARD_ID=id_do_board_aqui

# (Opcional) ID da lista alvo. Se preenchido, os prefixos abaixo são ignorados.
# Deixe vazio para que o sistema descubra as listas pelos prefixos automaticamente.
TRELLO_TARGET_LIST_ID=

# Prefixos das listas alvo separados por vírgula (sem o sufixo numérico como "(03)").
# Usado apenas quando TRELLO_TARGET_LIST_ID está vazio.
TRELLO_TARGET_LIST_PREFIXES=Pendentes Analise - Chamados,Lotes

# Mapeamento de labels do card para caminhos de repositórios locais.
# Formato JSON. A chave é o nome da label no Trello (ex: "repo:notro-api").
REPO_LABEL_MAP={"repo:notro-api":"/home/notro/Documentos/Notro","repo:notro-front":"/home/notro/Documentos/Notro/webapp-2"}

# Repositório padrão usado quando o card não tem label repo:*
DEFAULT_REPO_PATH=/home/notro/Documentos/Notro

# Configuração do Claude CLI
# Nome ou caminho do binário do Claude CLI
CLAUDE_BIN=claude

# Modelo a usar. Exemplos: sonnet, opus, haiku, claude-sonnet-4-6
CLAUDE_MODEL=sonnet

# Número máximo de turnos do Claude (limita o processamento e custo)
CLAUDE_MAX_TURNS=30

# Ordem dos fallbacks alternativos quando o Claude atingir limite.
# O padrão usa Gemini como fallback principal e DeepSeek como fallback econômico opcional.
# Exemplo para usar apenas modelo local: TRIAGE_FALLBACK_PROVIDERS=ollama
TRIAGE_FALLBACK_PROVIDERS=gemini,deepseek

# Chave da API do Gemini. Se ficar vazia, o fallback principal fica desabilitado.
GEMINI_API_KEY=

# Modelo principal do Gemini usado no fallback.
GEMINI_MODEL=gemini-2.5-pro

# Lista de modelos do Gemini tentados em sequência quando o principal falhar por cota/acesso.
# Exemplo: gemini-2.5-pro,gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-pro,gemini-2.5-flash

# Opcional: use apenas se precisar apontar para outro endpoint do Gemini.
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Chave da API do DeepSeek. Se ficar vazia, o fallback econômico fica desabilitado.
DEEPSEEK_API_KEY=

# Modelo do DeepSeek usado no fallback econômico.
DEEPSEEK_MODEL=deepseek-chat

# Opcional: use apenas se precisar apontar para outro endpoint compatível do DeepSeek.
DEEPSEEK_API_BASE_URL=https://api.deepseek.com

# Fallback local via Ollama. Não requer API key quando usado localmente.
# Modelo default para código/triagem local.
OLLAMA_MODEL=qwen2.5-coder:7b

# Aceita base URL com ou sem /api no final.
OLLAMA_API_BASE_URL=http://127.0.0.1:11434

# Mantém o modelo carregado para reduzir latência entre chamadas.
OLLAMA_KEEP_ALIVE=10m

# Ative apenas se estiver usando um modelo multimodal compatível com imagens.
OLLAMA_ATTACH_IMAGES=false

# Ajustes do contexto local do repositório enviado aos fallbacks por API.
TRIAGE_REPO_CONTEXT_SCAN_LIMIT=250
TRIAGE_REPO_CONTEXT_SNIPPET_LIMIT=6
TRIAGE_REPO_CONTEXT_FILE_BYTES_LIMIT=64000
TRIAGE_REPO_CONTEXT_TOTAL_CHARS_LIMIT=9000
TRIAGE_REPO_CONTEXT_TERMS_LIMIT=12

# URL pública do webhook (usada para validar assinatura HMAC do Trello)
TRELLO_WEBHOOK_CALLBACK_URL=https://edra-audiogenic-asunder.ngrok-free.dev/trello/webhook

# Defina como "true" para desabilitar a validação de assinatura em desenvolvimento
TRELLO_SKIP_SIGNATURE=true
