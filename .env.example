# Porta em que o servidor NestJS vai escutar
PORT=3080

# Credenciais da API do Trello
# Obtenha em: https://trello.com/app-key
TRELLO_KEY=sua_key_aqui
TRELLO_TOKEN=seu_token_aqui

# OAuth Secret da aplicação Trello (diferente do token).
# Obtenha em: https://trello.com/app-key → campo "Secret"
# Necessário apenas quando TRELLO_SKIP_SIGNATURE=false
TRELLO_OAUTH_SECRET=

# ID do board do Trello onde os cards serão monitorados
TRELLO_BOARD_ID=id_do_board_aqui

# (Opcional) ID da lista alvo. Se preenchido, os prefixos abaixo são ignorados.
# Deixe vazio para que o sistema descubra as listas pelos prefixos automaticamente.
TRELLO_TARGET_LIST_ID=

# Prefixos das listas alvo separados por vírgula (sem o sufixo numérico como "(03)").
# Usado apenas quando TRELLO_TARGET_LIST_ID está vazio.
TRELLO_TARGET_LIST_PREFIXES=Pendentes Analise - Chamados,Lotes

# Mapeamento de labels do card para caminhos de repositórios locais.
# Formato JSON. A chave é o nome da label no Trello (ex: "repo:notro-api").
REPO_LABEL_MAP={"repo:notro-api":"/home/notro/Documentos/Notro","repo:notro-front":"/home/notro/Documentos/Notro/webapp-2"}

# Repositório padrão usado quando o card não tem label repo:*
DEFAULT_REPO_PATH=/home/notro/Documentos/Notro

# Configuração do Claude CLI
# Nome ou caminho do binário do Claude CLI
CLAUDE_BIN=claude

# Modelo a usar. Exemplos: sonnet, opus, haiku, claude-sonnet-4-6
CLAUDE_MODEL=sonnet

# Número máximo de turnos do Claude (limita o processamento e custo)
CLAUDE_MAX_TURNS=6

# URL pública do webhook (usada para validar assinatura HMAC do Trello)
TRELLO_WEBHOOK_CALLBACK_URL=https://edra-audiogenic-asunder.ngrok-free.dev/trello/webhook

# Defina como "true" para desabilitar a validação de assinatura em desenvolvimento
TRELLO_SKIP_SIGNATURE=true
